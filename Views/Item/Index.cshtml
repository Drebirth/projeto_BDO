@model IEnumerable<projetoBDO.Entities.item.Item>

    @{
        ViewData["Title"] = "Item de grind";
    }

<h1>Itens cadastrados no sistema</h1>
<h2>Cadastrar novos Itens</h2>
<a asp-action="Create">Novo Item</a>
<table class="table">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(x => x.Id)</th>
            <th>@Html.DisplayNameFor(x => x.Nome)</th>
            <th>@Html.DisplayNameFor(x => x.Preco)</th>
           <!-- <th>@Html.DisplayNameFor(x => x.SpotId)</th>-->
            <th>@Html.DisplayNameFor(x => x.Spot.Nome)</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var item in Model)
        {
        <tr>
            <td>@Html.DisplayFor(model => item.Id)</td>
            <td>@Html.DisplayFor(model => item.Nome)</td>
            <td>@Html.DisplayFor(model => item.Preco)</td>
           <!-- <td>@Html.DisplayFor(model => item.SpotId)</td>-->
            <td>@Html.DisplayFor(model => item.Spot.Nome)</td>
        </tr>
        }
    </tbody>
</table>