@model projetoBDO.Entities.item.Item

@{
    ViewData["Title"] = "Editando Item";
}

<h1>Pagina de edição do Item</h1>
<form asp-action="Edit">
    <label>
        @Html.DisplayNameFor(x => x.Nome)
        <input type="text" asp-for="Nome" />
    </label>
    <label>
        @Html.DisplayNameFor(x => x.Preco)
        <input type="text" asp-for="Preco" />
    </label>
    <button type="submit">Salvar</button>
</form>