@model projetoBDO.Entities.item.Item


@{
    ViewData["Title"] = "Adicionar Item";
}
<h1>Inclusão de itens</h1>
<div class="login">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="All" class="text-danger"></div>
        <div class="row mb-3">
            <label class="col-sm-2 col-form-label">Nome Item</label>
                <div class="col-sm-10">
                    <input type="text" asp-for="Nome" class="form-control" />
                </div>
        </div>
        <label for="Preco">Preço do Item
            <input type="number" asp-for="Preco" />
        </label>
        
        <div>
            <button type="submit">Salvar</button>
        </div>
    </form>
</div>
<a asp-controller="Local" asp-action="Index" class="btn btn-primary">Voltar</a>

