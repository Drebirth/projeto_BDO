@model projetoBDO.Entities.grind.Grind

@{
    ViewData["Title"] = "Grind";
}

<h1>Jornada</h1>
<form asp-action="Create" method="post">
    <div class="row mb-3">
            <label asp-for="Personagem" class="form-label">Personagem</label>
            <input class="form-control" list="personagens" placeholder="Qual personagem" />
        </div>
        <div>
            <label  class="form-label">Data</label>
            <input type="date" name="" class="form-control"/>
        </div>
    </div>
    <button type="submit">Salvar</button>
</form>